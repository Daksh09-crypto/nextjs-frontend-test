# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnpm-store
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/jspm_packages
/web_modules

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc & OS system files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Ehthumbs.db
*.pem

# IDEs and Code Editors
.vscode/
!.vscode/extensions.json
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (safeguards your secrets)
.env*
.env.local
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts